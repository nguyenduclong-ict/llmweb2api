{
  "name": "llmweb2api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n be,web -c blue,green \"pnpm dev:backend\" \"pnpm dev:web\"",
    "dev:backend": "pnpm --filter @llmweb2api/backend dev",
    "dev:web": "pnpm --filter @llmweb2api/web dev",
    "build": "pnpm build:backend && pnpm build:web",
    "build:backend": "pnpm --filter @llmweb2api/backend build",
    "build:web": "pnpm --filter @llmweb2api/web build",
    "build+start:backend": "pnpm build:backend && pnpm start:backend",
    "start:backend": "pnpm --filter @llmweb2api/backend start",
    "start": "pnpm start:backend",
    "lint": "pnpm lint:backend",
    "lint:backend": "pnpm --filter @llmweb2api/backend lint",
    "lint:web": "pnpm --filter @llmweb2api/web lint",
    "lint:all": "pnpm lint:backend && pnpm lint:web",
    "format": "pnpm format:backend",
    "format:backend": "pnpm --filter @llmweb2api/backend format",
    "format:web": "pnpm --filter @llmweb2api/web format",
    "format:all": "pnpm format:backend && pnpm format:web",
    "format:check": "pnpm format:check:backend",
    "format:check:backend": "pnpm --filter @llmweb2api/backend format:check",
    "format:check:web": "pnpm --filter @llmweb2api/web format:check",
    "typecheck": "pnpm typecheck:backend",
    "typecheck:backend": "pnpm --filter @llmweb2api/backend typecheck",
    "typecheck:web": "pnpm --filter @llmweb2api/web typecheck",
    "typecheck:all": "pnpm typecheck:backend && pnpm typecheck:web",
    "check": "pnpm typecheck:all && pnpm lint:all && pnpm format:check:backend && pnpm format:check:web",
    "build-pow": "pnpm --filter @llmweb2api/backend build-pow"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "better-sqlite3",
      "keccak",
      "esbuild"
    ]
  }
}
