{
  "name": "@llmweb2api/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/copy_pow_assets.js",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "build-pow": "node scripts/build_pow_go.js",
    "test:chatgpt-provider": "tsx scripts/test_chatgpt_provider.ts",
    "test:temporary-vision": "tsx scripts/test_temporary_vision.ts",
    "test:delete-conversation": "tsx scripts/test_delete_conversation.ts"
  },
  "dependencies": {
    "@types/sql.js": "^1.4.11",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "keccak": "^3.0.4",
    "node-tls-client": "^2.1.0",
    "tiktoken": "^1.0.22",
    "uuid": "^11.1.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.2"
  }
}
